APP_ENV=development
APP_NAME=container-survey

WEB_PORT=3000
API_PORT=8080
WORKER_ENABLED=true

NEXT_PUBLIC_APP_NAME=Container Survey Management System
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080/api/v1

# Direct API run against Laragon MySQL (default Laragon: root without password)
DATABASE_URL=root@tcp(127.0.0.1:3306)/kontainer_db?parseTime=true&charset=utf8mb4&loc=Local
# Docker Compose uses its internal MySQL service instead of Laragon.
DOCKER_DATABASE_URL=gift:gift_password@tcp(mysql:3306)/kontainer_db?parseTime=true&charset=utf8mb4&loc=Local
MYSQL_DATABASE=kontainer_db
MYSQL_USER=gift
MYSQL_PASSWORD=gift_password
MYSQL_ROOT_PASSWORD=root_password

REDIS_ADDR=127.0.0.1:6379
REDIS_PASSWORD=

JWT_ACCESS_SECRET=change_me_access_secret
JWT_REFRESH_SECRET=change_me_refresh_secret
JWT_ACCESS_TTL_MINUTES=60
JWT_REFRESH_TTL_DAYS=14

S3_ENDPOINT=http://127.0.0.1:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=gift-survey
S3_REGION=us-east-1
S3_USE_SSL=false

MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

MAX_UPLOAD_MB=10
PDF_RENDER_TIMEOUT_SECONDS=120


